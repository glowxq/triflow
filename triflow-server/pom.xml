<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- 直接继承 Spring Boot Parent -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.9</version>
        <relativePath/>
    </parent>

    <groupId>com.glowxq.triflow</groupId>
    <artifactId>triflow</artifactId>
    <version>${revision}</version>
    <packaging>pom</packaging>
    <name>Triflow Server</name>
    <description>Triflow 三端企业级快速开发脚手架 - 后端服务 (Java 25 + Spring Boot 3.5)</description>

    <modules>
        <module>common</module>
        <module>dependencies</module>
        <module>business</module>
        <module>demo</module>
        <module>base</module>
    </modules>

    <!-- 配置全局属性 -->
    <properties>
        <!-- Triflow 版本 -->
        <revision>1.0.0</revision>
        <!-- Java 版本 -->
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <java.version>25</java.version>
        <!-- AI -->
        <spring-ai.version>1.1.1</spring-ai.version>
        <!-- 其他配置 -->
        <skipTests>true</skipTests>
        <flatten-maven-plugin.version>1.6.0</flatten-maven-plugin.version>
        <!-- 注解处理器版本（需与 dependencies 模块保持一致） -->
        <lombok.version>1.18.42</lombok.version>
        <mapstruct-plus.version>1.5.0</mapstruct-plus.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.glowxq.triflow</groupId>
                <artifactId>dependencies</artifactId>
                <version>${project.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <!-- Spring AI BOM (需在根 POM 直接导入，BOM 嵌套 import 不传递) -->
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>${spring-ai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!--全局通用依赖-->
    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
        </dependency>
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations</artifactId>
            <version>2.2.27</version>
        </dependency>
    </dependencies>
