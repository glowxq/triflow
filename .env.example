# ╔════════════════════════════════════════════════════════════╗
# ║             Triflow 环境变量配置                           ║
# ║  复制此文件为 .env 并根据需要修改                          ║
# ║  cp .env.example .env                                     ║
# ╚════════════════════════════════════════════════════════════╝

# ====== 数据库 (MySQL) ======
MYSQL_ROOT_PASSWORD=triflow123
MYSQL_DATABASE=triflow
MYSQL_USER=root
MYSQL_PASSWORD=triflow123
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ====== 缓存 (Redis) ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=triflow123
REDIS_DATABASE=6

# ====== 对象存储 (MinIO) ======
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=triflow
MINIO_SECRET_KEY=triflow123
MINIO_BUCKET=triflow
S3_ENABLED=true
S3_PROVIDER=MINIO
MINIO_REGION=us-east-1

# ====== 服务端口 ======
SERVER_PORT=7100
WEB_PORT=7200
SPRING_PROFILES_ACTIVE=local

# ====== 安全配置 ======
# SA_TOKEN_JWT_SECRET=triflow-jwt-secret-change-me-in-production

# ====== 可选：微信配置 ======
# WECHAT_APPID=your-wechat-appid
# WECHAT_SECRET=your-wechat-secret
# WECHAT_MCH_ID=your-mch-id
# WECHAT_MCH_KEY=your-mch-key
# WECHAT_API_V3_KEY=your-api-v3-key
# WECHAT_NOTIFY_URL=https://your-domain.com/wechat

# ====== 可选：飞书配置 ======
# FEISHU_APP_ID=your-feishu-app-id
# FEISHU_APP_SECRET=your-feishu-app-secret
# FEISHU_WEBHOOK_INTERNAL=https://open.feishu.cn/open-apis/bot/v2/hook/your-id
# FEISHU_WEBHOOK_BUSINESS=https://open.feishu.cn/open-apis/bot/v2/hook/your-id
# FEISHU_REDIRECT_URI=http://localhost:7200/auth/login

# ====== 可选：短信配置 ======
# ALIYUN_ACCESS_KEY=your-aliyun-access-key
# ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
# SMS_SIGN_NAME=your-sms-sign-name

# ====== 可选：AI 配置 ======
# AI_DEEPSEEK_API_KEY=sk-xxx
# AI_OPENAI_API_KEY=sk-xxx
# AI_ANTHROPIC_API_KEY=sk-xxx
# AI_ZHIPU_API_KEY=xxx.xxx
# ARK_API_KEY=your-ark-api-key
